# Required API Keys
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# Optional: Weather API (get free key from https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Slack Bot Token (get from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Optional: Google Calendar (download credentials.json from Google Cloud Console)
GOOGLE_CALENDAR_CREDENTIALS=credentials.json
